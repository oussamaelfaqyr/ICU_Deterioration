{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "histogram", "name": "Histogram", "version": ""}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "Prediction Rate (req/min)",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 15},
          "unit": "reqpm"
        }
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list"}},
      "targets": [
        {
          "expr": "rate(icu_predictions_total[1m]) * 60",
          "legendFormat": "{{risk_level}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "title": "p50 / p95 Latency",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "s", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(icu_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(icu_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },

    {
      "id": 3,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}
      },
      "targets": [
        {"expr": "sum(icu_predictions_total)", "legendFormat": "Total", "refId": "A"}
      ]
    },

    {
      "id": 4,
      "title": "High Risk Alerts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }
      },
      "targets": [
        {"expr": "sum(icu_predictions_total{risk_level=\"HIGH\"})", "legendFormat": "HIGH", "refId": "A"}
      ]
    },

    {
      "id": 5,
      "title": "Champion Model Version",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}
      },
      "targets": [
        {"expr": "icu_model_version", "legendFormat": "Version", "refId": "A"}
      ]
    },

    {
      "id": 6,
      "title": "Risk Score Distribution",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "custom": {"lineWidth": 2, "fillOpacity": 20}}
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(icu_risk_score_bucket[5m]))",
          "legendFormat": "p50 score",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(icu_risk_score_bucket[5m]))",
          "legendFormat": "p95 score",
          "refId": "B"
        }
      ]
    },

    {
      "id": 7,
      "title": "Feature PSI Drift (Top 20)",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "PSI"},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 0.1},
                    {"color": "red", "value": 0.25}
                  ]
                }
              },
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          }
        ]
      },
      "options": {"sortBy": [{"displayName": "PSI", "desc": true}]},
      "targets": [
        {
          "expr": "topk(20, icu_feature_psi)",
          "legendFormat": "{{feature}}",
          "refId": "A",
          "instant": true
        }
      ],
      "transformations": [
        {"id": "labelsToFields", "options": {"valueLabel": "feature"}},
        {"id": "organize", "options": {"renameByName": {"feature": "Feature", "Value": "PSI"}}}
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["icu", "mlops", "monitoring"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "ICU Deterioration — MLOps Monitor",
  "uid": "icu-mlops-v1",
  "version": 1
}
